generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}


model InventoryItem {
  id        String   @id @default(cuid())
  name      String
  type      String
  imageUrl  String
  sizes     Json
  price     Int      @default(0)
  quantity  Int
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Sale {
  id              String   @id @default(cuid())
  receiptNumber   String   @unique
  customerName    String?
  customerPhone   String?
  items           Json     // CartItem[]
  subtotal        Int
  totalDiscount   Int
  grandTotal      Int
  amountPaid      Int
  balance         Int
  paymentType     String   // "full" | "deposit"
  depositDeadline DateTime?
  status          String   // "completed" | "pending_balance"
  soldBy          String?
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // ITEM_ADD, ITEM_UPDATE, ITEM_DELETE, SALE_COMPLETE, SALE_UPDATE
  entityType  String   // "INVENTORY" | "SALE"
  entityId    String
  performedBy String?
  details     Json?    // { before: ..., after: ..., reason: ... }
  createdAt   DateTime @default(now())

  @@index([createdAt])
}