generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model InventoryItem {
  id        String   @id @default(cuid())
  name      String
  type      String
  imageUrl  String
  sizes     Json
  quantity  Int
  createdAt DateTime @default(now())
  price     Int      @default(0)

  @@index([createdAt])
}

model Sale {
  id              String    @id @default(cuid())
  receiptNumber   String    @unique
  customerName    String?
  customerPhone   String?
  items           Json
  subtotal        Int
  totalDiscount   Int
  grandTotal      Int
  amountPaid      Int
  balance         Int
  paymentType     String
  depositDeadline DateTime?
  status          String
  soldBy          String?
  createdAt       DateTime  @default(now())

  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  performedBy String?
  details     Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}
